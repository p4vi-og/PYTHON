def cop(a,b):
    return riz(a,b)==1
    
def riz(a,b):
    while(b!=0):
        rem=a%b
        temp=b
        b=rem
        a=temp
    return a

n=int(input("Enter the Number:"))
for a in range(5,n):
    for b in range(4,a):
        for c in range(3,b):
            if c*c+b*b==a*a and cop(a,b) and cop(b,c) and cop(a,c):
                print(c,b,a)

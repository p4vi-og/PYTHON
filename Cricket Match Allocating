a=int(input("Enter Number of Teams:"))
teams=[]
for i in range(a):
    x=input("Enter Team:")
    teams.append(x)
matches=[]
for i in range(a-1):
    for j in range(i+1,a):
        matches.append([teams[i],teams[j]])
pos=1        
for i in matches:
    print("Match{}:{} vs {}".format(pos,i[0],i[1]))
pos=pos+1    
